---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const leaders = [
  { titleKey: 'leadership.director', roleKey: 'leadership.director.role' },
  { titleKey: 'leadership.medical', roleKey: 'leadership.medical.role' },
  { titleKey: 'leadership.nurse', roleKey: 'leadership.nurse.role' },
  { titleKey: 'leadership.finance', roleKey: 'leadership.finance.role' },
];

const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>';
---

<section class="py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-12">
      <SectionBadge text={t(lang, 'leadership.badge')} icon={badgeIcon} />
      <h2 class="text-3xl sm:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, 'leadership.title')}</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {leaders.map((leader) => (
        <div class="text-center">
          <div class="w-24 h-24 rounded-full bg-stone-200 mx-auto mb-4 flex items-center justify-center">
            <svg class="w-10 h-10 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
            </svg>
          </div>
          <h3 class="font-bold text-stone-900">{t(lang, leader.titleKey)}</h3>
          <p class="text-sm text-stone-500 mt-1">{t(lang, leader.roleKey)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
