---
import { t, type Locale } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section class="py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-12 reveal">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-stone-900 tracking-tight">{t(lang, 'hero.title')}</h1>
      <p class="mt-4 text-lg text-stone-500">{t(lang, 'hero.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-6">
      <!-- Emergency -->
      <a href="tel:+38232325602" class="transition-transform duration-200 ease-out hover:-translate-y-0.5 group relative bg-red-50 border border-red-100 rounded-xl sm:rounded-2xl p-3 sm:p-8 flex items-center gap-3 sm:block reveal">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-red-100 flex items-center justify-center shrink-0 sm:mb-4 group-hover:bg-red-200 transition-colors">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <h2 class="text-sm sm:text-lg font-bold text-red-900 leading-tight">{t(lang, 'quick.emergency.title')}</h2>
          <p class="text-xs sm:text-sm text-red-700 leading-tight mt-0.5 sm:mt-1 line-clamp-2">{t(lang, 'quick.emergency.desc')}</p>
        </div>
      </a>

      <!-- Working hours -->
      <a href={(lang === 'cnr' ? '' : `/${lang}`) + '/contact/'} class="transition-transform duration-200 ease-out hover:-translate-y-0.5 group bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-3 sm:p-8 flex items-center gap-3 sm:block reveal">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-stone-100 flex items-center justify-center shrink-0 sm:mb-4 group-hover:bg-emerald-100 transition-colors">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-stone-600 group-hover:text-emerald-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <h2 class="text-sm sm:text-lg font-bold text-stone-900 leading-tight">{t(lang, 'quick.hours.title')}</h2>
          <p class="text-xs sm:text-sm text-stone-500 leading-tight mt-0.5 sm:mt-1 line-clamp-2">{t(lang, 'quick.hours.desc')}</p>
        </div>
      </a>

      <!-- Clinics -->
      <a href={(lang === 'cnr' ? '/' : `/${lang}/`) + '#clinics'} class="transition-transform duration-200 ease-out hover:-translate-y-0.5 group bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-3 sm:p-8 flex items-center gap-3 sm:block reveal">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-stone-100 flex items-center justify-center shrink-0 sm:mb-4 group-hover:bg-emerald-100 transition-colors">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-stone-600 group-hover:text-emerald-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <div class="min-w-0">
          <h2 class="text-sm sm:text-lg font-bold text-stone-900 leading-tight">{t(lang, 'quick.clinics.title')}</h2>
          <p class="text-xs sm:text-sm text-stone-500 leading-tight mt-0.5 sm:mt-1 line-clamp-2">{t(lang, 'quick.clinics.desc')}</p>
        </div>
      </a>

      <!-- Directions -->
      <a href={(lang === 'cnr' ? '' : `/${lang}`) + '/contact/'} class="transition-transform duration-200 ease-out hover:-translate-y-0.5 group bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-3 sm:p-8 flex items-center gap-3 sm:block reveal">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-stone-100 flex items-center justify-center shrink-0 sm:mb-4 group-hover:bg-emerald-100 transition-colors">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-stone-600 group-hover:text-emerald-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <h2 class="text-sm sm:text-lg font-bold text-stone-900 leading-tight">{t(lang, 'quick.directions.title')}</h2>
          <p class="text-xs sm:text-sm text-stone-500 leading-tight mt-0.5 sm:mt-1 line-clamp-2">{t(lang, 'quick.directions.desc')}</p>
        </div>
      </a>

      <!-- Appointment -->
      <a href={(lang === 'cnr' ? '' : `/${lang}`) + '/contact/'} class="transition-transform duration-200 ease-out hover:-translate-y-0.5 group bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-3 sm:p-8 flex items-center gap-3 sm:block reveal">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-stone-100 flex items-center justify-center shrink-0 sm:mb-4 group-hover:bg-emerald-100 transition-colors">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-stone-600 group-hover:text-emerald-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <h2 class="text-sm sm:text-lg font-bold text-stone-900 leading-tight">{t(lang, 'quick.appointment.title')}</h2>
          <p class="text-xs sm:text-sm text-stone-500 leading-tight mt-0.5 sm:mt-1 line-clamp-2">{t(lang, 'quick.appointment.desc')}</p>
        </div>
      </a>

      <!-- eZdravlje -->
      <a href="https://ezdravlje.me" target="_blank" rel="noopener" class="transition-transform duration-200 ease-out hover:-translate-y-0.5 group bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-3 sm:p-8 flex items-center gap-3 sm:block reveal">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-stone-100 flex items-center justify-center shrink-0 sm:mb-4 group-hover:bg-emerald-100 transition-colors">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-stone-600 group-hover:text-emerald-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <h2 class="text-sm sm:text-lg font-bold text-stone-900 leading-tight">{t(lang, 'quick.results.title')}</h2>
          <p class="text-xs sm:text-sm text-stone-500 leading-tight mt-0.5 sm:mt-1 line-clamp-2">{t(lang, 'quick.results.desc')}</p>
        </div>
      </a>
    </div>
  </div>
</section>
