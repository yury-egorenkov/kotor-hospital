---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>';

const hoursRows = [
  { labelKey: 'contact.hours.emergency', valueKey: 'contact.hours.emergency.value', border: true },
  { labelKey: 'contact.hours.clinics', valueKey: 'contact.hours.clinics.value', border: true },
  { labelKey: 'contact.hours.radiology', valueKey: 'contact.hours.radiology.value', border: true },
  { labelKey: 'contact.hours.radiology.sat', valueKey: 'contact.hours.radiology.sat.value', border: true },
  { labelKey: 'contact.hours.lab', valueKey: 'contact.hours.lab.value', border: false },
];

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
---

<main>
  <section class="py-12 sm:py-20 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8 sm:mb-12">
        <SectionBadge text={t(lang, 'contact.badge')} icon={badgeIcon} />
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, 'contact.title')}</h1>
        <p class="mt-3 sm:mt-4 text-base sm:text-lg text-stone-500">{t(lang, 'contact.subtitle')}</p>
      </div>

      <div class="space-y-8 sm:space-y-12">
        <!-- Contact info -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'contact.badge')}</h2>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-white border border-stone-200 rounded-xl p-4 sm:p-5">
              <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2">{t(lang, 'contact.address.label')}</h3>
              <p class="text-base font-semibold text-stone-900">{t(lang, 'contact.address.street')}</p>
              <p class="text-sm text-stone-600">{t(lang, 'contact.address.city')}</p>
            </div>
            <div class="bg-white border border-stone-200 rounded-xl p-4 sm:p-5">
              <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2">{t(lang, 'contact.phone.label')}</h3>
              <a href="tel:+38232325602" class="text-base font-semibold text-stone-900 hover:text-emerald-600 transition-colors">{t(lang, 'emergency.phone')}</a>
            </div>
            <div class="bg-white border border-stone-200 rounded-xl p-4 sm:p-5">
              <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2">{t(lang, 'contact.email.label')}</h3>
              <a href="mailto:obk@t-com.me" class="text-base font-semibold text-stone-900 hover:text-emerald-600 transition-colors">obk@t-com.me</a>
            </div>
            <div class="bg-white border border-stone-200 rounded-xl p-4 sm:p-5">
              <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2">{t(lang, 'contact.branch.label')}</h3>
              <p class="text-sm text-stone-600">{t(lang, 'contact.branch.address')}</p>
            </div>
          </div>
        </div>

        <!-- Working hours -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'contact.hours.label')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <table class="w-full text-sm">
              <tbody>
                {hoursRows.map((row) => (
                  <tr class={row.border ? 'border-b border-stone-200' : ''}>
                    <td class="py-3 font-medium text-stone-900 whitespace-nowrap">{t(lang, row.labelKey)}</td>
                    <td class="py-3 text-stone-600 text-right whitespace-nowrap">{t(lang, row.valueKey)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Directions -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'contact.directions.label')}</h2>
          </div>
          <div class="space-y-3">
            <div class="bg-white border border-stone-200 rounded-xl p-4 sm:p-5">
              <h3 class="font-semibold text-stone-900 text-sm mb-2">{t(lang, 'contact.directions.kotor.title')}</h3>
              <p class="text-sm text-stone-600">{t(lang, 'contact.directions.kotor.desc')}</p>
            </div>
            <div class="bg-white border border-stone-200 rounded-xl p-4 sm:p-5">
              <h3 class="font-semibold text-stone-900 text-sm mb-2">{t(lang, 'contact.directions.tivat.title')}</h3>
              <p class="text-sm text-stone-600">{t(lang, 'contact.directions.tivat.desc')}</p>
            </div>
            <div class="bg-white border border-stone-200 rounded-xl p-4 sm:p-5">
              <h3 class="font-semibold text-stone-900 text-sm mb-2">{t(lang, 'contact.directions.hn.title')}</h3>
              <p class="text-sm text-stone-600">{t(lang, 'contact.directions.hn.desc')}</p>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div>
          <div class="rounded-2xl overflow-hidden border border-stone-200">
            <iframe
              src="https://www.google.com/maps?q=Opšta+bolnica+Kotor,+Škaljari,+Kotor,+Montenegro&z=15&output=embed"
              class="w-full aspect-[21/9] border-0"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={t(lang, 'contact.map.title')}
            ></iframe>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12">
        <a href={homeHref} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
