---
import { t, type Locale } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<div class="bg-gradient-to-r from-amber-400 to-amber-500 text-amber-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-center gap-x-1.5 text-center flex-wrap text-sm font-medium">
    <span>{t(lang, 'demo.text')}</span>
    <a href="https://github.com/yury-egorenkov/kotor-hospital" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 font-semibold hover:text-amber-800 transition-colors">GitHub</a>
    <span class="text-amber-700">·</span>
    <a href="/project-report-viewer.html" class="underline underline-offset-2 font-semibold hover:text-amber-800 transition-colors">Project Report</a>
    <span class="text-amber-700">·</span>
    <a href="https://egorsky.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 font-semibold hover:text-amber-800 transition-colors">egorsky.com</a>
  </div>
</div>
