---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>';

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
---

<main>
  <section class="py-12 sm:py-20 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8 sm:mb-12 reveal">
        <SectionBadge text={t(lang, 'laboratory.badge')} icon={badgeIcon} />
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, 'laboratory.title')}</h1>
        <p class="mt-3 sm:mt-4 text-base sm:text-lg text-stone-500">{t(lang, 'laboratory.subtitle')}</p>
      </div>

      <div class="space-y-8 sm:space-y-12">
        <!-- Test types -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'laboratory.tests.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'laboratory.tests.p1')}</p>
              <p>{t(lang, 'laboratory.tests.p2')}</p>
            </div>
          </div>
        </div>

        <!-- Preparation -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'laboratory.preparation.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'laboratory.preparation.p1')}</p>
              <p>{t(lang, 'laboratory.preparation.p2')}</p>
            </div>
          </div>
        </div>

        <!-- Working hours -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'laboratory.hours.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'laboratory.hours.p1')}</p>
              <p>{t(lang, 'laboratory.hours.p2')}</p>
            </div>
          </div>
        </div>

        <!-- Results -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-violet-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'laboratory.results.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'laboratory.results.p1')}</p>
              <p>{t(lang, 'laboratory.results.p2')}</p>
            </div>
          </div>
        </div>

        <!-- eZdravlje portal -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-stone-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'laboratory.ezdravlje.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'laboratory.ezdravlje.p1')}</p>
              <p>{t(lang, 'laboratory.ezdravlje.p2')}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12 reveal">
        <a href={homeHref} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
