---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const clinics = [
  {
    key: 'surgery',
    iconBg: 'bg-emerald-100',
    iconColor: 'text-emerald-600',
    iconPath: 'M12 4v16m8-8H4',
  },
  {
    key: 'internal',
    iconBg: 'bg-blue-100',
    iconColor: 'text-blue-600',
    iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    key: 'dermatology',
    iconBg: 'bg-amber-100',
    iconColor: 'text-amber-600',
    iconPath: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  },
  {
    key: 'ophthalmology',
    iconBg: 'bg-cyan-100',
    iconColor: 'text-cyan-600',
    iconPaths: [
      'M15 12a3 3 0 11-6 0 3 3 0 016 0z',
      'M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
    ],
  },
  {
    key: 'endocrinology',
    iconBg: 'bg-rose-100',
    iconColor: 'text-rose-600',
    iconPath: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  },
  {
    key: 'gastroenterology',
    iconBg: 'bg-orange-100',
    iconColor: 'text-orange-600',
    iconPath: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  },
];

const clinicBase = lang === 'cnr' ? '/clinics/' : `/${lang}/clinics/`;
const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>';
---

<section id="clinics" class="py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-12">
      <SectionBadge text={t(lang, 'clinics.badge')} icon={badgeIcon} />
      <h2 class="text-3xl sm:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, 'clinics.title')}</h2>
      <p class="mt-4 text-lg text-stone-500">{t(lang, 'clinics.subtitle')}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-6">
      {clinics.map((clinic) => (
        <a href={clinicBase + clinic.key + '/'} class="group bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-3 sm:p-6 flex items-center gap-3 sm:block hover:border-stone-300 hover:shadow-md transition-all">
          <div class={`w-10 h-10 rounded-lg ${clinic.iconBg} flex items-center justify-center shrink-0 sm:mb-4`}>
            <svg class={`w-5 h-5 ${clinic.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              {'iconPaths' in clinic
                ? clinic.iconPaths!.map((p: string) => <path stroke-linecap="round" stroke-linejoin="round" d={p}/>)
                : <path stroke-linecap="round" stroke-linejoin="round" d={clinic.iconPath}/>
              }
            </svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm sm:text-base font-bold text-stone-900 leading-tight group-hover:text-emerald-700 transition-colors">{t(lang, `clinic.${clinic.key}.name`)}</h3>
            <p class="text-xs sm:text-sm text-stone-500 mt-0.5 sm:mt-1 line-clamp-2">{t(lang, `clinic.${clinic.key}.desc`)}</p>
            <div class="text-xs text-stone-400 flex items-center gap-1.5 mt-0.5 sm:mt-3">
              <svg class="w-3.5 h-3.5 shrink-0 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              {t(lang, 'clinics.hours')}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
