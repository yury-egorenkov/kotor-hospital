---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const badgeIcon = '<svg class="w-3 h-3 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>';

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
const mapSrc = 'https://www.google.com/maps?q=Filijala+Meljine,+Herceg+Novi,+Montenegro&z=15&output=embed';
---

<main>
  <!-- Gradient page header -->
  <div class="bg-gradient-to-br from-stone-800 via-stone-900 to-emerald-900 py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionBadge text={t(lang, 'meljine.badge')} icon={badgeIcon} variant="light" />
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white tracking-tight">{t(lang, 'meljine.title')}</h1>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-stone-300">{t(lang, 'meljine.subtitle')}</p>
    </div>
  </div>

  <section class="py-8 sm:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Photo -->
      <div class="mb-6 sm:mb-8">
        <img src="/images/hospital-meljine.jpg" alt={t(lang, 'meljine.title')} class="w-full rounded-xl sm:rounded-2xl object-cover max-h-80 shadow-lg" loading="lazy" />
      </div>

      <div class="space-y-6 sm:space-y-8">
        <!-- Rehabilitation -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'meljine.rehabilitation.title')}</h2>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'meljine.rehabilitation.p1')}</p>
              <p>{t(lang, 'meljine.rehabilitation.p2')}</p>
            </div>
          </div>
        </div>

        <!-- Location -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'meljine.location.title')}</h2>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'meljine.location.p1')}</p>
              <p>{t(lang, 'meljine.location.p2')}</p>
            </div>
            <div class="mt-4">
              <iframe src={mapSrc} class="w-full h-56 sm:h-64 rounded-lg border-0" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
          </div>
        </div>

        <!-- Working hours -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'meljine.hours.title')}</h2>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'meljine.hours.p1')}</p>
              <p>{t(lang, 'meljine.hours.p2')}</p>
            </div>
          </div>
        </div>

        <!-- Contact -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-violet-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'meljine.contact.title')}</h2>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'meljine.contact.p1')}</p>
              <p>{t(lang, 'meljine.contact.p2')}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12">
        <a href={homeHref} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
