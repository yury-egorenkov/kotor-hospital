---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const badgeIcon = '<svg class="w-3 h-3 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>';

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
---

<main>
  <!-- Gradient page header -->
  <div class="bg-gradient-to-br from-cyan-900 via-teal-900 to-cyan-900 py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionBadge text={t(lang, 'news.badge')} icon={badgeIcon} variant="light" />
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white tracking-tight">{t(lang, 'news.title')}</h1>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-cyan-200/80">{t(lang, 'news.subtitle')}</p>
    </div>
  </div>

  <section class="py-8 sm:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="space-y-6 sm:space-y-8">
        <!-- Expansion project -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'news.expansion.title')}</h2>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'news.expansion.p1')}</p>
              <p>{t(lang, 'news.expansion.p2')}</p>
            </div>
          </div>
        </div>

        <!-- TELE.DOC -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'news.teledoc.title')}</h2>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'news.teledoc.p1')}</p>
              <p>{t(lang, 'news.teledoc.p2')}</p>
            </div>
          </div>
        </div>

        <!-- Equipment -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-violet-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'news.equipment.title')}</h2>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'news.equipment.p1')}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12">
        <a href={homeHref} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
