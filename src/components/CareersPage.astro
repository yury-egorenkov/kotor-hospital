---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>';

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
---

<main>
  <section class="py-12 sm:py-20 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8 sm:mb-12">
        <SectionBadge text={t(lang, 'careers.badge')} icon={badgeIcon} />
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, 'careers.title')}</h1>
        <p class="mt-3 sm:mt-4 text-base sm:text-lg text-stone-500">{t(lang, 'careers.subtitle')}</p>
      </div>

      <div class="space-y-8 sm:space-y-12">
        <!-- About working -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'careers.about.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'careers.about.p1')}</p>
              <p>{t(lang, 'careers.about.p2')}</p>
            </div>
          </div>
        </div>

        <!-- Openings -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'careers.openings.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'careers.openings.p1')}</p>
              <p>{t(lang, 'careers.openings.p2')}</p>
            </div>
          </div>
        </div>

        <!-- HR Contact -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-violet-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'careers.contact.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
              <p>{t(lang, 'careers.contact.p1')}</p>
              <p>{t(lang, 'careers.contact.p2')}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12">
        <a href={homeHref} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
