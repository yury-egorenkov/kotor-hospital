---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
  slug: string;
}

const { lang, slug } = Astro.props;

const clinicConfig: Record<string, { iconBg: string; iconColor: string; iconPath: string; iconPaths?: string[] }> = {
  surgery: { iconBg: 'bg-emerald-100', iconColor: 'text-emerald-600', iconPath: 'M12 4v16m8-8H4' },
  internal: { iconBg: 'bg-blue-100', iconColor: 'text-blue-600', iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  dermatology: { iconBg: 'bg-amber-100', iconColor: 'text-amber-600', iconPath: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01' },
  ophthalmology: { iconBg: 'bg-cyan-100', iconColor: 'text-cyan-600', iconPath: '', iconPaths: ['M15 12a3 3 0 11-6 0 3 3 0 016 0z', 'M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'] },
  endocrinology: { iconBg: 'bg-rose-100', iconColor: 'text-rose-600', iconPath: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
  gastroenterology: { iconBg: 'bg-orange-100', iconColor: 'text-orange-600', iconPath: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
};

const clinic = clinicConfig[slug] || clinicConfig.surgery;
const checkSvg = '<svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>';

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
---

<main>
  <section class="py-12 sm:py-20 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8 sm:mb-12">
        <SectionBadge text={t(lang, 'clinics.badge')} icon={badgeIcon} />
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class={`w-11 h-11 sm:w-14 sm:h-14 rounded-xl ${clinic.iconBg} flex items-center justify-center shrink-0`}>
            <svg class={`w-6 h-6 sm:w-7 sm:h-7 ${clinic.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              {clinic.iconPaths
                ? clinic.iconPaths.map((p) => <path stroke-linecap="round" stroke-linejoin="round" d={p}/>)
                : <path stroke-linecap="round" stroke-linejoin="round" d={clinic.iconPath}/>
              }
            </svg>
          </div>
          <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, `clinic.${slug}.name`)}</h1>
        </div>
        <p class="text-base sm:text-lg text-stone-500">{t(lang, `clinic.${slug}.detail`)}</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-6 sm:gap-8">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-6 sm:space-y-8">
          <!-- Services -->
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <h2 class="text-base sm:text-lg font-bold text-stone-900 mb-3 sm:mb-4">{t(lang, 'dept.services')}</h2>
            <ul class="space-y-2.5 sm:space-y-3 text-sm sm:text-base text-stone-600">
              <li class="flex items-start gap-2"><Fragment set:html={checkSvg} />{t(lang, `clinic.${slug}.service1`)}</li>
              <li class="flex items-start gap-2"><Fragment set:html={checkSvg} />{t(lang, `clinic.${slug}.service2`)}</li>
              <li class="flex items-start gap-2"><Fragment set:html={checkSvg} />{t(lang, `clinic.${slug}.service3`)}</li>
            </ul>
          </div>

          <!-- Photo placeholder -->
          <div class="bg-stone-100 border border-stone-200 rounded-xl sm:rounded-2xl aspect-video flex items-center justify-center">
            <div class="text-center text-stone-400">
              <svg class="w-10 h-10 sm:w-12 sm:h-12 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z"/>
              </svg>
              <span class="text-sm">{t(lang, 'clinics.photo')}</span>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-4 sm:space-y-6">
          <!-- Working hours -->
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2 sm:mb-3">{t(lang, 'contact.hours.label')}</h3>
            <div class="flex items-center gap-2 text-stone-700">
              <svg class="w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-sm font-medium">{t(lang, 'clinics.hours')}</span>
            </div>
          </div>

          <!-- Location -->
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2 sm:mb-3">{t(lang, 'contact.address.label')}</h3>
            <p class="text-sm text-stone-700 font-medium">{t(lang, 'contact.address.street')}</p>
            <p class="text-sm text-stone-500">{t(lang, 'contact.address.city')}</p>
          </div>

          <!-- Appointment -->
          <div class="bg-emerald-50 border border-emerald-100 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <h3 class="text-sm font-semibold text-emerald-700 mb-2">{t(lang, 'quick.appointment.title')}</h3>
            <p class="text-sm text-emerald-600 mb-3">{t(lang, 'quick.appointment.desc')}</p>
            <a href="tel:+38232325602" class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {t(lang, 'header.phone')}
            </a>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12">
        <a href={homeHref + '#clinics'} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'clinics.back')}
        </a>
      </div>
    </div>
  </section>
</main>
