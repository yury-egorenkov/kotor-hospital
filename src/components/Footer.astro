---
import { t, type Locale } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<footer class="bg-gradient-to-b from-stone-900 to-stone-950 text-stone-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-10">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <svg class="w-9 h-9" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="36" height="36" rx="8" fill="#059669"/>
            <rect x="16" y="7" width="4" height="9" rx="2" fill="#fff"/>
            <rect x="16" y="20" width="4" height="9" rx="2" fill="#fff"/>
            <rect x="7" y="16" width="9" height="4" rx="2" fill="#fff"/>
            <rect x="20" y="16" width="9" height="4" rx="2" fill="#fff"/>
          </svg>
          <div>
            <span class="text-[11px] uppercase tracking-wider text-stone-400 leading-none block">{t(lang, 'header.name.label')}</span>
            <span class="text-base font-semibold text-white leading-tight block">{t(lang, 'header.name.city')}</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed">{t(lang, 'footer.brand.desc')}</p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{t(lang, 'footer.nav')}</h3>
        <ul class="space-y-2.5">
          <li><a href={(lang === 'cnr' ? '/' : `/${lang}/`) + '#departments'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'nav.departments')}</a></li>
          <li><a href={(lang === 'cnr' ? '/' : `/${lang}/`) + '#clinics'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'nav.clinics')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/about/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'nav.about')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/contact/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'nav.contact')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/patients/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'nav.patients')}</a></li>
        </ul>
      </div>

      <!-- Services & Info -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{t(lang, 'footer.services')}</h3>
        <ul class="space-y-2.5">
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/insurance/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'insurance.badge')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/laboratory/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'laboratory.badge')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/prices/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'prices.badge')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/faq/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'faq.badge')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/news/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'news.badge')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/careers/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'careers.badge')}</a></li>
          <li><a href={(lang === 'cnr' ? '' : `/${lang}`) + '/meljine/'} class="text-sm hover:text-emerald-400 transition-colors">{t(lang, 'meljine.badge')}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{t(lang, 'footer.contact')}</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="tel:+38232325602" class="hover:text-white transition-colors">{t(lang, 'emergency.phone')}</a></li>
          <li><a href="mailto:obk@t-com.me" class="hover:text-white transition-colors">obk@t-com.me</a></li>
          <li>{t(lang, 'contact.address.street')}, 85331 Kotor</li>
          <li>{t(lang, 'contact.address.city').split(',').pop()?.trim()}</li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{t(lang, 'footer.links')}</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="https://ezdravlje.me" target="_blank" rel="noopener" class="hover:text-white transition-colors">{t(lang, 'footer.links.ezdravlje')}</a></li>
          <li><a href="tel:+38232325602" class="hover:text-white transition-colors">{t(lang, 'footer.links.emergency')}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-stone-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-stone-500">{t(lang, 'footer.copyright')}</p>
      <p class="text-xs text-stone-500">Website by <a href="https://egorsky.com" target="_blank" rel="noopener" class="text-stone-400 hover:text-white transition-colors">egorsky.com</a></p>
    </div>
  </div>
</footer>
