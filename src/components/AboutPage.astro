---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';

const leaders = [
  { titleKey: 'leadership.director', roleKey: 'leadership.director.role' },
  { titleKey: 'leadership.medical', roleKey: 'leadership.medical.role' },
  { titleKey: 'leadership.nurse', roleKey: 'leadership.nurse.role' },
  { titleKey: 'leadership.finance', roleKey: 'leadership.finance.role' },
];

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
---

<main>
  <section class="py-12 sm:py-20 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8 sm:mb-12 reveal">
        <SectionBadge text={t(lang, 'about.badge')} icon={badgeIcon} />
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, 'about.title')}</h1>
        <p class="mt-3 sm:mt-4 text-base sm:text-lg text-stone-500">{t(lang, 'about.subtitle')}</p>
      </div>

      <div class="space-y-8 sm:space-y-12">
        <!-- About text -->
        <div class="reveal">
          <div class="space-y-4 text-stone-600 leading-relaxed">
            <p>{t(lang, 'about.p1')}</p>
            <p>{t(lang, 'about.p2')}</p>
            <p>{t(lang, 'about.p3')}</p>
          </div>
        </div>

        <!-- Photo gallery -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-stone-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'about.gallery.title')}</h2>
          </div>
          <div class="grid grid-cols-2 gap-3 sm:gap-4">
            <div class="col-span-2 sm:col-span-1 rounded-xl sm:rounded-2xl overflow-hidden border border-stone-200">
              <img src="/images/hospital-building.jpg" alt={t(lang, 'about.gallery.building')} class="w-full h-48 sm:h-56 object-cover" loading="lazy" />
              <div class="px-3 py-2 bg-white"><p class="text-xs text-stone-500">{t(lang, 'about.gallery.building')}</p></div>
            </div>
            <div class="col-span-2 sm:col-span-1 rounded-xl sm:rounded-2xl overflow-hidden border border-stone-200">
              <img src="/images/hospital-main.jpeg" alt={t(lang, 'about.gallery.main')} class="w-full h-48 sm:h-56 object-cover" loading="lazy" />
              <div class="px-3 py-2 bg-white"><p class="text-xs text-stone-500">{t(lang, 'about.gallery.main')}</p></div>
            </div>
            <div class="col-span-2 sm:col-span-1 rounded-xl sm:rounded-2xl overflow-hidden border border-stone-200">
              <img src="/images/hospital-expansion.png" alt={t(lang, 'about.gallery.expansion')} class="w-full h-48 sm:h-56 object-cover" loading="lazy" />
              <div class="px-3 py-2 bg-white"><p class="text-xs text-stone-500">{t(lang, 'about.gallery.expansion')}</p></div>
            </div>
            <div class="col-span-2 sm:col-span-1 rounded-xl sm:rounded-2xl overflow-hidden border border-stone-200">
              <img src="/images/hospital-meljine.jpg" alt={t(lang, 'about.gallery.meljine')} class="w-full h-48 sm:h-56 object-cover" loading="lazy" />
              <div class="px-3 py-2 bg-white"><p class="text-xs text-stone-500">{t(lang, 'about.gallery.meljine')}</p></div>
            </div>
          </div>
        </div>

        <!-- Stats grid -->
        <div class="reveal">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="bg-stone-50 rounded-2xl p-6 text-center">
              <div class="text-3xl sm:text-4xl font-extrabold text-stone-900 mb-1">~250</div>
              <div class="text-sm text-stone-500">{t(lang, 'about.stat.employees')}</div>
            </div>
            <div class="bg-stone-50 rounded-2xl p-6 text-center">
              <div class="text-3xl sm:text-4xl font-extrabold text-stone-900 mb-1">~60</div>
              <div class="text-sm text-stone-500">{t(lang, 'about.stat.doctors')}</div>
            </div>
            <div class="bg-stone-50 rounded-2xl p-6 text-center">
              <div class="text-3xl sm:text-4xl font-extrabold text-stone-900 mb-1">3</div>
              <div class="text-sm text-stone-500">{t(lang, 'about.stat.municipalities')}</div>
            </div>
            <div class="bg-stone-50 rounded-2xl p-6 text-center">
              <div class="text-3xl sm:text-4xl font-extrabold text-stone-900 mb-1">&euro;9M</div>
              <div class="text-sm text-stone-500">{t(lang, 'about.stat.expansion')}</div>
            </div>
          </div>
        </div>

        <!-- Mission -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'about.mission.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <p class="text-sm sm:text-base text-stone-600 leading-relaxed">{t(lang, 'about.mission.desc')}</p>
          </div>
        </div>

        <!-- Projects -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'about.projects.title')}</h2>
          </div>
          <div class="space-y-3">
            <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-5">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-emerald-900 text-sm">{t(lang, 'about.project.expansion.title')}</h3>
                  <p class="text-sm text-emerald-700 mt-1">{t(lang, 'about.project.expansion.desc')}</p>
                </div>
              </div>
            </div>
            <div class="bg-blue-50 border border-blue-100 rounded-xl p-5">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-blue-900 text-sm">{t(lang, 'about.project.teledoc.title')}</h3>
                  <p class="text-sm text-blue-700 mt-1">{t(lang, 'about.project.teledoc.desc')}</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Leadership -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-violet-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'leadership.title')}</h2>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {leaders.map((leader) => (
              <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6 text-center">
                <div class="w-16 h-16 rounded-full bg-stone-200 mx-auto mb-3 flex items-center justify-center">
                  <svg class="w-7 h-7 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                  </svg>
                </div>
                <h3 class="font-bold text-stone-900 text-sm">{t(lang, leader.titleKey)}</h3>
                <p class="text-xs text-stone-500 mt-1">{t(lang, leader.roleKey)}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Meljine branch -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'about.meljine.title')}</h2>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <p class="text-sm sm:text-base text-stone-600 leading-relaxed">{t(lang, 'about.meljine.desc')}</p>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12 reveal">
        <a href={homeHref} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
