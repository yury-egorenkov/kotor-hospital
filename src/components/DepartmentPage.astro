---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
  slug: string;
}

const { lang, slug } = Astro.props;

const deptConfig: Record<string, { iconBg: string; iconColor: string; iconPath: string; color: string }> = {
  emergency: { iconBg: 'bg-red-100', iconColor: 'text-red-600', iconPath: 'M13 10V3L4 14h7v7l9-11h-7z', color: 'red' },
  surgery: { iconBg: 'bg-emerald-100', iconColor: 'text-emerald-600', iconPath: 'M12 4v16m8-8H4', color: 'emerald' },
  gynecology: { iconBg: 'bg-pink-100', iconColor: 'text-pink-600', iconPath: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', color: 'pink' },
  internal: { iconBg: 'bg-blue-100', iconColor: 'text-blue-600', iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', color: 'blue' },
  radiology: { iconBg: 'bg-violet-100', iconColor: 'text-violet-600', iconPath: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', color: 'violet' },
};

const nurseCount: Record<string, number> = {
  emergency: 0, surgery: 3, gynecology: 0, internal: 0, radiology: 0,
};

const dept = deptConfig[slug] || deptConfig.emergency;
const nurses = nurseCount[slug] || 0;
const checkSvg = '<svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>';
const personSvg = '<svg class="w-16 h-16 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>';
const personSmallSvg = '<svg class="w-6 h-6 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>';

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;

const hasKey = (key: string) => t(lang, key) !== key;
const hasExperience = (n: number) => hasKey(`dept.${slug}.doctor${n}.experience`);
const hasEducation = (n: number) => hasKey(`dept.${slug}.doctor${n}.education`);

// Conditional section flags
const hasStats = hasKey(`dept.${slug}.stat1.value`);
const hasAbout = hasKey(`dept.${slug}.about.p1`);
const hasPatientPrep = hasKey(`dept.${slug}.prep.title`);
const hasEquipment = hasKey(`dept.${slug}.equip.item1`);

// Dynamic specialists: doctor2..doctorN (doctor1 = head, rendered separately)
const specialists: number[] = [];
for (let i = 2; i <= 10; i++) {
  if (hasKey(`dept.${slug}.doctor${i}.name`)) {
    specialists.push(i);
  } else {
    break;
  }
}

// Dynamic services: iterate service1..service8, stop when key doesn't exist
const services: string[] = [];
for (let i = 1; i <= 8; i++) {
  const key = `dept.${slug}.service${i}`;
  if (hasKey(key)) {
    services.push(t(lang, key));
  } else {
    break;
  }
}

// Stats config for gradient cards
const statGradients = [
  'from-emerald-50 to-teal-50',
  'from-blue-50 to-cyan-50',
  'from-violet-50 to-purple-50',
  'from-amber-50 to-orange-50',
];
const statIcons = [
  '<svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>',
  '<svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>',
  '<svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>',
  '<svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
];
---

<main>
  <!-- Gradient page header -->
  <div class="bg-gradient-to-br from-emerald-900 via-teal-900 to-emerald-900 py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionBadge text={t(lang, 'departments.badge')} icon={badgeIcon} />
      <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
        <div class={`w-11 h-11 sm:w-14 sm:h-14 rounded-xl ${dept.iconBg} flex items-center justify-center shrink-0`}>
          <svg class={`w-6 h-6 sm:w-7 sm:h-7 ${dept.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d={dept.iconPath}/>
          </svg>
        </div>
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white tracking-tight">{t(lang, `dept.${slug}.name`)}</h1>
      </div>
      <p class="text-base sm:text-lg text-emerald-200/80">{t(lang, `dept.${slug}.desc`)}</p>
    </div>
  </div>

  <!-- Quick Stats Bar -->
  {hasStats && (
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-10">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
        {[1, 2, 3, 4].map((n, i) => (
          <div class={`bg-gradient-to-br ${statGradients[i]} rounded-xl sm:rounded-2xl p-4 sm:p-5 shadow-sm border border-white/60`}>
            <div class="flex items-center gap-3">
              <Fragment set:html={statIcons[i]} />
              <div>
                <p class="text-xl sm:text-2xl font-extrabold text-stone-900">{t(lang, `dept.${slug}.stat${n}.value`)}</p>
                <p class="text-xs sm:text-sm text-stone-600">{t(lang, `dept.${slug}.stat${n}.label`)}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <section class={hasStats ? 'py-8 sm:py-12' : 'py-8 sm:py-12'}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Main content + Sidebar grid -->
      <div class="grid lg:grid-cols-3 gap-6 sm:gap-8">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-5 sm:space-y-6">

          <!-- About the Department -->
          {hasAbout && (
            <div class="bg-white border border-stone-100 rounded-xl sm:rounded-2xl shadow-sm p-4 sm:p-6">
              <div class="flex items-center gap-2 mb-3 sm:mb-4">
                <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                </svg>
                <h2 class="text-base sm:text-lg font-bold text-stone-900">{t(lang, 'dept.about.title')}</h2>
              </div>
              <div class="space-y-3 text-sm sm:text-base text-stone-600 leading-relaxed">
                <p>{t(lang, `dept.${slug}.about.p1`)}</p>
                {hasKey(`dept.${slug}.about.p2`) && <p>{t(lang, `dept.${slug}.about.p2`)}</p>}
                {hasKey(`dept.${slug}.about.p3`) && <p>{t(lang, `dept.${slug}.about.p3`)}</p>}
              </div>
            </div>
          )}

          <!-- Services -->
          <div class="bg-white border border-stone-100 rounded-xl sm:rounded-2xl shadow-sm p-4 sm:p-6">
            <h2 class="text-base sm:text-lg font-bold text-stone-900 mb-3 sm:mb-4">{t(lang, 'dept.services')}</h2>
            <ul class={`text-sm sm:text-base text-stone-600 ${services.length > 3 ? 'grid sm:grid-cols-2 gap-x-4 gap-y-2.5 sm:gap-y-3' : 'space-y-2.5 sm:space-y-3'}`}>
              {services.map((svc) => (
                <li class="flex items-start gap-2"><Fragment set:html={checkSvg} />{svc}</li>
              ))}
            </ul>
          </div>

          <!-- For Patients -->
          {hasPatientPrep && (
            <div class="bg-white border border-stone-100 rounded-xl sm:rounded-2xl shadow-sm p-4 sm:p-6">
              <div class="flex items-center gap-2 mb-4 sm:mb-5">
                <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/>
                </svg>
                <h2 class="text-base sm:text-lg font-bold text-stone-900">{t(lang, 'dept.patients.title')}</h2>
              </div>

              <!-- Before Your Surgery -->
              <div class="mb-5 sm:mb-6">
                <h3 class="text-sm font-semibold text-stone-700 mb-2.5">{t(lang, `dept.${slug}.prep.title`)}</h3>
                <ul class="space-y-2 text-sm text-stone-600">
                  {[1, 2, 3, 4, 5].map((n) => (
                    hasKey(`dept.${slug}.prep.item${n}`) && (
                      <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                        {t(lang, `dept.${slug}.prep.item${n}`)}
                      </li>
                    )
                  ))}
                </ul>
              </div>

              <div class="border-t border-stone-100 pt-5 sm:pt-6">
                <h3 class="text-sm font-semibold text-stone-700 mb-2.5">{t(lang, `dept.${slug}.bring.title`)}</h3>
                <ul class="space-y-2 text-sm text-stone-600">
                  {[1, 2, 3, 4, 5].map((n) => (
                    hasKey(`dept.${slug}.bring.item${n}`) && (
                      <li class="flex items-start gap-2">
                        <Fragment set:html={checkSvg} />
                        {t(lang, `dept.${slug}.bring.item${n}`)}
                      </li>
                    )
                  ))}
                </ul>
              </div>
            </div>
          )}

          <!-- Equipment & Technology -->
          {hasEquipment && (
            <div class="bg-white border border-stone-100 rounded-xl sm:rounded-2xl shadow-sm p-4 sm:p-6">
              <div class="flex items-center gap-2 mb-3 sm:mb-4">
                <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-3.77a1 1 0 01-.17-1.45l2.72-3.45a1 1 0 011.46-.1l5.1 3.78m-5.1 3.78l5.1-3.78m-5.1 3.78L4.2 18.34a1 1 0 01-.82.42H2m9.42-3.59l5.1 3.78m0 0l3.24 2.4a1 1 0 00.82.18l1.2-.24M22 12l-2.16-1.62"/>
                </svg>
                <h2 class="text-base sm:text-lg font-bold text-stone-900">{t(lang, 'dept.equipment.title')}</h2>
              </div>
              <div class="grid sm:grid-cols-2 gap-3">
                {[1, 2, 3, 4].map((n) => (
                  hasKey(`dept.${slug}.equip.item${n}`) && (
                    <div class="flex items-start gap-3 bg-stone-50 rounded-lg p-3">
                      <svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>
                      <p class="text-sm text-stone-600">{t(lang, `dept.${slug}.equip.item${n}`)}</p>
                    </div>
                  )
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-4 sm:space-y-6 lg:sticky lg:top-24 lg:self-start">
          <!-- Working hours -->
          <div class="bg-white border border-stone-100 rounded-xl sm:rounded-2xl shadow-sm p-4 sm:p-6">
            <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2 sm:mb-3">{t(lang, 'contact.hours.label')}</h3>
            <div class="flex items-center gap-2 text-stone-700">
              <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-sm font-medium">{t(lang, `dept.${slug}.hours`)}</span>
            </div>
          </div>

          <!-- Phone -->
          {slug === 'emergency' && (
            <div class="bg-red-50 border border-red-100 rounded-xl sm:rounded-2xl p-4 sm:p-6">
              <h3 class="text-sm font-semibold text-red-400 uppercase tracking-wider mb-2 sm:mb-3">{t(lang, 'contact.phone.label')}</h3>
              <a href="tel:+38232325602" class="flex items-center gap-2 text-red-700 font-semibold">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {t(lang, 'emergency.phone')}
              </a>
              <p class="text-xs text-red-500 mt-1">{t(lang, 'emergency.247')}</p>
            </div>
          )}

          <!-- Location -->
          <div class="bg-white border border-stone-100 rounded-xl sm:rounded-2xl shadow-sm p-4 sm:p-6">
            <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2 sm:mb-3">{t(lang, 'contact.address.label')}</h3>
            <p class="text-sm text-stone-700 font-medium">{t(lang, 'contact.address.street')}</p>
            <p class="text-sm text-stone-500">{t(lang, 'contact.address.city')}</p>
          </div>

          <!-- Appointment -->
          <div class="bg-emerald-50 border border-emerald-100 rounded-xl sm:rounded-2xl p-4 sm:p-6">
            <h3 class="text-sm font-semibold text-emerald-700 mb-2">{t(lang, 'quick.appointment.title')}</h3>
            <p class="text-sm text-emerald-600 mb-3">{t(lang, 'quick.appointment.desc')}</p>
            <a href="tel:+38232325602" class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {t(lang, 'header.phone')}
            </a>
          </div>
        </div>
      </div>

      <!-- Team section — full width, outside grid -->
      <div class="mt-10 sm:mt-14">

        <!-- A. Head of Department — hero card -->
        <div class="bg-white border border-stone-100 rounded-xl sm:rounded-2xl shadow-sm overflow-hidden mb-4 sm:mb-5">
          <div class="flex flex-col sm:flex-row">
            <!-- Photo — 50% width on desktop, portrait ratio drives card height -->
            <div class="sm:w-1/2 shrink-0">
              <div class="aspect-[3/4] bg-stone-100 relative">
                <img
                  src={`/images/doctors/${slug}-1.jpg`}
                  alt={t(lang, `dept.${slug}.doctor1.name`)}
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
                <div class="absolute inset-0 items-center justify-center" style="display:none">
                  <Fragment set:html={personSvg} />
                </div>
              </div>
            </div>
            <!-- Details -->
            <div class="p-5 sm:p-8 flex flex-col justify-center">
              <span class="inline-flex items-center self-start px-2.5 py-0.5 rounded-full text-[11px] font-semibold bg-emerald-100 text-emerald-700 mb-3">
                {t(lang, 'dept.head.badge')}
              </span>
              <h3 class="text-xl sm:text-2xl font-bold text-stone-900 mb-1.5">{t(lang, `dept.${slug}.doctor1.name`)}</h3>
              <p class="text-sm sm:text-base font-medium text-stone-600 mb-1">{t(lang, `dept.${slug}.doctor1.title`)}</p>
              <p class="text-sm text-stone-500 mb-4">{t(lang, `dept.${slug}.doctor1.spec`)}</p>
              <div class="space-y-2 text-sm text-stone-500">
                {hasExperience(1) && (
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0"/>
                    </svg>
                    <span>{t(lang, `dept.${slug}.doctor1.experience`)}</span>
                  </div>
                )}
                {hasEducation(1) && (
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342"/>
                    </svg>
                    <span>{t(lang, `dept.${slug}.doctor1.education`)}</span>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- B. Specialists — grid, clearly smaller than head -->
        <div class="grid sm:grid-cols-2 gap-4 sm:gap-5 mb-4 sm:mb-5">
          {specialists.map((n) => (
            <div class="bg-white border border-stone-100 rounded-xl sm:rounded-2xl shadow-sm overflow-hidden">
              <div class="aspect-square bg-stone-100 relative">
                <img
                  src={`/images/doctors/${slug}-${n}.jpg`}
                  alt={t(lang, `dept.${slug}.doctor${n}.name`)}
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
                <div class="absolute inset-0 items-center justify-center" style="display:none">
                  <Fragment set:html={personSvg} />
                </div>
              </div>
              <div class="p-4 sm:p-5">
                <h3 class="text-base font-bold text-stone-900 mb-0.5">{t(lang, `dept.${slug}.doctor${n}.name`)}</h3>
                <p class="text-sm text-stone-600 mb-1">{t(lang, `dept.${slug}.doctor${n}.spec`)}</p>
                {hasExperience(n) && (
                  <p class="text-xs text-stone-400">{t(lang, `dept.${slug}.doctor${n}.experience`)}</p>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- C. Nursing staff — compact row -->
        {nurses > 0 && (
          <div>
            <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-3">{t(lang, 'dept.nurses.label')}</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {Array.from({ length: nurses }, (_, i) => i + 1).map((n) => (
                <div class="bg-stone-50 border border-stone-100 rounded-xl p-3 flex items-center gap-3">
                  <div class="w-12 h-12 rounded-full bg-stone-200 shrink-0 relative overflow-hidden">
                    <img
                      src={`/images/doctors/${slug}-nurse-${n}.jpg`}
                      alt={t(lang, `dept.${slug}.nurse${n}.name`)}
                      class="w-full h-full object-cover"
                      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                    />
                    <div class="absolute inset-0 items-center justify-center" style="display:none">
                      <Fragment set:html={personSmallSvg} />
                    </div>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-stone-800 truncate">{t(lang, `dept.${slug}.nurse${n}.name`)}</p>
                    <p class="text-xs text-stone-500 truncate">{t(lang, `dept.${slug}.nurse${n}.role`)}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12">
        <a href={homeHref + '#departments'} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
