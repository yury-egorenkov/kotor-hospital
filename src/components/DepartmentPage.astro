---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
  slug: string;
}

const { lang, slug } = Astro.props;

const deptConfig: Record<string, { iconBg: string; iconColor: string; iconPath: string; color: string }> = {
  emergency: { iconBg: 'bg-red-100', iconColor: 'text-red-600', iconPath: 'M13 10V3L4 14h7v7l9-11h-7z', color: 'red' },
  surgery: { iconBg: 'bg-emerald-100', iconColor: 'text-emerald-600', iconPath: 'M12 4v16m8-8H4', color: 'emerald' },
  gynecology: { iconBg: 'bg-pink-100', iconColor: 'text-pink-600', iconPath: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', color: 'pink' },
  internal: { iconBg: 'bg-blue-100', iconColor: 'text-blue-600', iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', color: 'blue' },
  radiology: { iconBg: 'bg-violet-100', iconColor: 'text-violet-600', iconPath: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', color: 'violet' },
};

const dept = deptConfig[slug] || deptConfig.emergency;
const checkSvg = '<svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>';

const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
---

<main>
  <section class="py-12 sm:py-20 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8 sm:mb-12 reveal">
        <SectionBadge text={t(lang, 'departments.badge')} icon={badgeIcon} />
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class={`w-11 h-11 sm:w-14 sm:h-14 rounded-xl ${dept.iconBg} flex items-center justify-center shrink-0`}>
            <svg class={`w-6 h-6 sm:w-7 sm:h-7 ${dept.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={dept.iconPath}/>
            </svg>
          </div>
          <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, `dept.${slug}.name`)}</h1>
        </div>
        <p class="text-base sm:text-lg text-stone-500">{t(lang, `dept.${slug}.desc`)}</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-6 sm:gap-8">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-6 sm:space-y-8">
          <!-- Services -->
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6 reveal">
            <h2 class="text-base sm:text-lg font-bold text-stone-900 mb-3 sm:mb-4">{t(lang, 'dept.services')}</h2>
            <ul class="space-y-2.5 sm:space-y-3 text-sm sm:text-base text-stone-600">
              <li class="flex items-start gap-2"><Fragment set:html={checkSvg} />{t(lang, `dept.${slug}.service1`)}</li>
              <li class="flex items-start gap-2"><Fragment set:html={checkSvg} />{t(lang, `dept.${slug}.service2`)}</li>
              <li class="flex items-start gap-2"><Fragment set:html={checkSvg} />{t(lang, `dept.${slug}.service3`)}</li>
            </ul>
          </div>

          <!-- Photo placeholder -->
          <div class="bg-stone-100 border border-stone-200 rounded-xl sm:rounded-2xl aspect-video flex items-center justify-center reveal">
            <div class="text-center text-stone-400">
              <svg class="w-10 h-10 sm:w-12 sm:h-12 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z"/>
              </svg>
              <span class="text-sm">{t(lang, 'departments.photo')}</span>
            </div>
          </div>

          <!-- Team placeholder -->
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6 reveal">
            <h2 class="text-base sm:text-lg font-bold text-stone-900 mb-3 sm:mb-4">{t(lang, 'dept.team')}</h2>
            <div class="grid sm:grid-cols-2 gap-3 sm:gap-4">
              {[1, 2].map(() => (
                <div class="flex items-center gap-3 p-3 rounded-xl bg-stone-50">
                  <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-stone-200 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                    </svg>
                  </div>
                  <div>
                    <div class="h-3 w-24 bg-stone-200 rounded mb-1.5"></div>
                    <div class="h-2.5 w-32 bg-stone-100 rounded"></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-4 sm:space-y-6">
          <!-- Working hours -->
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6 reveal">
            <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2 sm:mb-3">{t(lang, 'contact.hours.label')}</h3>
            <div class="flex items-center gap-2 text-stone-700">
              <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-sm font-medium">{t(lang, `dept.${slug}.hours`)}</span>
            </div>
          </div>

          <!-- Phone -->
          {slug === 'emergency' && (
            <div class="bg-red-50 border border-red-100 rounded-xl sm:rounded-2xl p-4 sm:p-6 reveal">
              <h3 class="text-sm font-semibold text-red-400 uppercase tracking-wider mb-2 sm:mb-3">{t(lang, 'contact.phone.label')}</h3>
              <a href="tel:+38232325602" class="flex items-center gap-2 text-red-700 font-semibold">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {t(lang, 'emergency.phone')}
              </a>
              <p class="text-xs text-red-500 mt-1">{t(lang, 'emergency.247')}</p>
            </div>
          )}

          <!-- Location -->
          <div class="bg-white border border-stone-200 rounded-xl sm:rounded-2xl p-4 sm:p-6 reveal">
            <h3 class="text-sm font-semibold text-stone-400 uppercase tracking-wider mb-2 sm:mb-3">{t(lang, 'contact.address.label')}</h3>
            <p class="text-sm text-stone-700 font-medium">{t(lang, 'contact.address.street')}</p>
            <p class="text-sm text-stone-500">{t(lang, 'contact.address.city')}</p>
          </div>

          <!-- Appointment -->
          <div class="bg-emerald-50 border border-emerald-100 rounded-xl sm:rounded-2xl p-4 sm:p-6 reveal">
            <h3 class="text-sm font-semibold text-emerald-700 mb-2">{t(lang, 'quick.appointment.title')}</h3>
            <p class="text-sm text-emerald-600 mb-3">{t(lang, 'quick.appointment.desc')}</p>
            <a href="tel:+38232325602" class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {t(lang, 'header.phone')}
            </a>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12 reveal">
        <a href={homeHref + '#departments'} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
