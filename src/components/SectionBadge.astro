---
interface Props {
  text: string;
  icon: string;
  variant?: 'default' | 'light';
}

const { text, icon, variant = 'default' } = Astro.props;

const isLight = variant === 'light';
const containerClass = isLight
  ? 'inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/20 bg-white/10 mb-3'
  : 'inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-emerald-200 bg-emerald-50 mb-3';
const iconBgClass = isLight
  ? 'w-5 h-5 rounded-full bg-white/20 flex items-center justify-center'
  : 'w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center';
const textClass = isLight
  ? 'text-xs font-semibold text-white/90 uppercase tracking-wider'
  : 'text-xs font-semibold text-emerald-700 uppercase tracking-wider';
---

<div class={containerClass}>
  <span class={iconBgClass}>
    <Fragment set:html={icon} />
  </span>
  <span class={textClass}>{text}</span>
</div>
