---
interface Props {
  text: string;
  icon: string;
}

const { text, icon } = Astro.props;
---

<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-emerald-200 bg-emerald-50 mb-3">
  <span class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center">
    <Fragment set:html={icon} />
  </span>
  <span class="text-xs font-semibold text-emerald-700 uppercase tracking-wider">{text}</span>
</div>
