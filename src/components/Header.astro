---
import { t, type Locale } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-stone-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-18">
      <!-- Logo -->
      <a href={lang === 'cnr' ? '/' : `/${lang}/`} class="flex items-center gap-3 shrink-0">
        <div class="w-9 h-9 rounded-lg bg-emerald-600 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
        </div>
        <div class="hidden sm:block">
          <span class="text-base font-bold text-stone-900 leading-tight block">{t(lang, 'header.name')}</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-8">
        <a href="#departments" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">{t(lang, 'nav.departments')}</a>
        <a href="#clinics" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">{t(lang, 'nav.clinics')}</a>
        <a href="#about" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">{t(lang, 'nav.about')}</a>
        <a href="#contact" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">{t(lang, 'nav.contact')}</a>
        <a href={(lang === 'cnr' ? '' : `/${lang}`) + '/patients/'} class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">{t(lang, 'nav.patients')}</a>
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <LanguageSwitcher lang={lang} />
        <a href="tel:+38232325602" class="hidden sm:flex items-center gap-2 text-sm font-medium text-stone-700 hover:text-stone-900 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {t(lang, 'header.phone')}
        </a>
        <a href="tel:+38232325602" class="inline-flex items-center gap-2 px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          <span class="hidden sm:inline">{t(lang, 'header.emergency')}</span>
          <span class="sm:hidden">{t(lang, 'header.emergency.short')}</span>
        </a>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 -mr-2 text-stone-600 hover:text-stone-900" aria-label={t(lang, 'header.menu.aria')}>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
