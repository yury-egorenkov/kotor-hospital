---
import { t, getLocalePath, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const badgeIcon = '<svg class="w-3 h-3 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>';
const checkSvg = '<svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';

const docItems = ['patients.docs.id', 'patients.docs.referral', 'patients.docs.insurance', 'patients.docs.meds', 'patients.docs.results', 'patients.docs.personal'];
const rightItems = ['patients.rights.info', 'patients.rights.consent', 'patients.rights.privacy', 'patients.rights.opinion', 'patients.rights.complaint'];
const visitItems = ['patients.visiting.hours', 'patients.visiting.persons', 'patients.visiting.children', 'patients.visiting.hygiene', 'patients.visiting.food'];
const insuranceHref = getLocalePath(lang, '/insurance/');
const homeHref = lang === 'cnr' ? '/' : `/${lang}/`;
---

<main>
  <!-- Gradient page header -->
  <div class="bg-gradient-to-br from-emerald-900 via-green-900 to-emerald-900 py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionBadge text={t(lang, 'patients.badge')} icon={badgeIcon} variant="light" />
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white tracking-tight">{t(lang, 'patients.title')}</h1>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-emerald-200/80">{t(lang, 'patients.description')}</p>
    </div>
  </div>

  <section class="py-8 sm:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="space-y-6 sm:space-y-8">
        <!-- Documents -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <div>
              <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'patients.docs.title')}</h2>
              <p class="text-xs sm:text-sm text-stone-500">{t(lang, 'patients.docs.subtitle')}</p>
            </div>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <ul class="space-y-2.5 sm:space-y-3 text-sm sm:text-base text-stone-600">
              {docItems.map((key) => (
                <li class="flex items-start gap-2">
                  <Fragment set:html={checkSvg} />
                  {t(lang, key)}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Patient rights -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div>
              <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'patients.rights.title')}</h2>
              <p class="text-xs sm:text-sm text-stone-500">{t(lang, 'patients.rights.subtitle')}</p>
            </div>
          </div>
          <div class="bg-stone-50 border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <ul class="space-y-2.5 sm:space-y-3 text-sm sm:text-base text-stone-600">
              {rightItems.map((key) => (
                <li class="flex items-start gap-2">
                  <Fragment set:html={checkSvg} />
                  {t(lang, key)}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Visiting hours -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'patients.visiting.title')}</h2>
              <p class="text-xs sm:text-sm text-stone-500">{t(lang, 'patients.visiting.subtitle')}</p>
            </div>
          </div>
          <div class="bg-white border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <ul class="space-y-2.5 sm:space-y-3 text-sm sm:text-base text-stone-600">
              {visitItems.map((key) => (
                <li class="flex items-start gap-2">
                  <Fragment set:html={checkSvg} />
                  {t(lang, key)}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Insurance -->
        <div>
          <div class="flex items-center gap-3 mb-3 sm:mb-4">
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-violet-100 flex items-center justify-center shrink-0">
              <svg class="w-4.5 h-4.5 sm:w-5 sm:h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            </div>
            <div>
              <h2 class="text-lg sm:text-xl font-bold text-stone-900">{t(lang, 'patients.insurance.title')}</h2>
              <p class="text-xs sm:text-sm text-stone-500">{t(lang, 'patients.insurance.subtitle')}</p>
            </div>
          </div>
          <div class="bg-stone-50 border border-stone-100 rounded-xl shadow-sm p-4 sm:p-5">
            <p class="text-sm sm:text-base text-stone-600 leading-relaxed">{t(lang, 'patients.insurance.summary')}</p>
            <a href={insuranceHref} class="inline-flex items-center gap-1.5 mt-3 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
              {t(lang, 'patients.insurance.more')}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Back link -->
      <div class="mt-8 sm:mt-12">
        <a href={homeHref} class="inline-flex items-center gap-2 text-sm font-medium text-emerald-600 hover:text-emerald-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          {t(lang, 'patients.back')}
        </a>
      </div>
    </div>
  </section>
</main>
