---
import { t, type Locale } from '../i18n/utils';
import SectionBadge from './SectionBadge.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const deptBase = lang === 'cnr' ? '/departments/' : `/${lang}/departments/`;

const departments = [
  {
    key: 'emergency',
    iconBg: 'bg-red-100',
    iconColor: 'text-red-600',
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
    borderColor: 'border-l-red-500',
  },
  {
    key: 'surgery',
    iconBg: 'bg-emerald-100',
    iconColor: 'text-emerald-600',
    iconPath: 'M12 4v16m8-8H4',
    borderColor: 'border-l-emerald-500',
  },
  {
    key: 'gynecology',
    iconBg: 'bg-pink-100',
    iconColor: 'text-pink-600',
    iconPath: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
    borderColor: 'border-l-pink-500',
  },
  {
    key: 'internal',
    iconBg: 'bg-blue-100',
    iconColor: 'text-blue-600',
    iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    borderColor: 'border-l-blue-500',
  },
  {
    key: 'radiology',
    iconBg: 'bg-violet-100',
    iconColor: 'text-violet-600',
    iconPath: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    borderColor: 'border-l-violet-500',
  },
];

const badgeIcon = '<svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>';
---

<section id="departments" class="py-10 sm:py-14 lg:py-16 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-8">
      <SectionBadge text={t(lang, 'departments.badge')} icon={badgeIcon} />
      <h2 class="text-3xl sm:text-4xl font-extrabold text-stone-900 tracking-tight">{t(lang, 'departments.title')}</h2>
      <p class="mt-4 text-lg text-stone-500">{t(lang, 'departments.subtitle')}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2.5 sm:gap-4">
      {departments.map((dept, index) => (
        <div class="reveal" style={`animation-delay: ${index * 80}ms`}>
          <a href={deptBase + dept.key + '/'} class={`group bg-white border border-stone-100 border-l-4 ${dept.borderColor} rounded-xl p-3 sm:p-4 shadow-sm hover:shadow-md transition-all flex items-center gap-3 h-full`}>
            <div class={`w-10 h-10 rounded-lg ${dept.iconBg} flex items-center justify-center shrink-0`}>
              <svg class={`w-5 h-5 ${dept.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={dept.iconPath}/>
              </svg>
            </div>
            <div class="min-w-0">
              <h3 class="text-sm sm:text-base font-bold text-stone-900 leading-tight group-hover:text-emerald-700 transition-colors">{t(lang, `dept.${dept.key}.name`)}</h3>
              <p class="text-xs sm:text-sm text-stone-500 mt-0.5 sm:mt-1 line-clamp-2">{t(lang, `dept.${dept.key}.desc`)}</p>
              <div class="flex items-center gap-1.5 text-xs text-stone-400 mt-0.5 sm:mt-1">
                <svg class="w-3.5 h-3.5 shrink-0 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {t(lang, `dept.${dept.key}.hours`).includes(' / ')
                  ? t(lang, `dept.${dept.key}.hours`).split(' / ').map((part, i, arr) => (
                      <>{i > 0 && <><span class="hidden sm:inline"> / </span><br class="sm:hidden" /></>}{part}</>
                    ))
                  : t(lang, `dept.${dept.key}.hours`)
                }
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
