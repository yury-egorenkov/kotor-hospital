---
import '../styles/global.css';
import { t, locales, localeFlags, localeLabels, type Locale } from '../i18n/utils';

// Pre-render all translations for client-side switching
const allTranslations: Record<string, Record<string, string>> = {};
for (const loc of locales) {
  allTranslations[loc] = {
    'site.title': t(loc, 'site.title'),
    'header.name': t(loc, 'header.name'),
    'header.phone': t(loc, 'header.phone'),
    'header.emergency': t(loc, 'header.emergency'),
    'header.emergency.short': t(loc, 'header.emergency.short'),
    'nav.departments': t(loc, 'nav.departments'),
    'nav.clinics': t(loc, 'nav.clinics'),
    'nav.about': t(loc, 'nav.about'),
    'nav.contact': t(loc, 'nav.contact'),
    'nav.patients': t(loc, 'nav.patients'),
    'emergency.phone': t(loc, 'emergency.phone'),
    'emergency.mobile': t(loc, 'emergency.mobile'),
    'error.404.title': t(loc, 'error.404.title'),
    'error.404.desc': t(loc, 'error.404.desc'),
    'error.404.home': t(loc, 'error.404.home'),
    'error.404.call': t(loc, 'error.404.call'),
    'footer.brand.desc': t(loc, 'footer.brand.desc'),
    'footer.nav': t(loc, 'footer.nav'),
    'footer.contact': t(loc, 'footer.contact'),
    'footer.links': t(loc, 'footer.links'),
    'footer.links.ezdravlje': t(loc, 'footer.links.ezdravlje'),
    'footer.links.emergency': t(loc, 'footer.links.emergency'),
    'footer.copyright': t(loc, 'footer.copyright'),
    'contact.address.street': t(loc, 'contact.address.street'),
    'contact.address.city': t(loc, 'contact.address.city'),
  };
}

// Default lang for SSR
const lang: Locale = 'cnr';
const homeHref = (l: string) => l === 'cnr' ? '/' : `/${l}/`;
const patientsHref = (l: string) => l === 'cnr' ? '/patients/' : `/${l}/patients/`;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>404 — {t(lang, 'site.title')}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="bg-stone-50 text-stone-800 font-sans antialiased flex flex-col min-h-screen">

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-18">
        <a data-href="home" href="/" class="flex items-center gap-3 shrink-0">
          <div class="w-9 h-9 rounded-lg bg-emerald-600 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          </div>
          <div class="hidden sm:block">
            <span data-t="header.name" class="text-base font-bold text-stone-900 leading-tight block">{t(lang, 'header.name')}</span>
          </div>
        </a>
        <nav class="hidden lg:flex items-center gap-8">
          <a data-href="home-hash-departments" href="/#departments" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors" data-t="nav.departments">{t(lang, 'nav.departments')}</a>
          <a data-href="home-hash-clinics" href="/#clinics" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors" data-t="nav.clinics">{t(lang, 'nav.clinics')}</a>
          <a data-href="home-hash-about" href="/#about" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors" data-t="nav.about">{t(lang, 'nav.about')}</a>
          <a data-href="home-hash-contact" href="/#contact" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors" data-t="nav.contact">{t(lang, 'nav.contact')}</a>
          <a data-href="patients" href="/patients/" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors" data-t="nav.patients">{t(lang, 'nav.patients')}</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="tel:+38232325602" class="hidden sm:flex items-center gap-2 text-sm font-medium text-stone-700 hover:text-stone-900 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span data-t="header.phone">{t(lang, 'header.phone')}</span>
          </a>
          <a href="tel:+38232325602" class="inline-flex items-center gap-2 px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <span class="hidden sm:inline" data-t="header.emergency">{t(lang, 'header.emergency')}</span>
            <span class="sm:hidden" data-t="header.emergency.short">{t(lang, 'header.emergency.short')}</span>
          </a>
          <button id="mobile-menu-btn" class="lg:hidden p-2 -mr-2 text-stone-600 hover:text-stone-900">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-overlay fixed inset-0 z-40 lg:hidden">
    <div class="absolute inset-0 bg-stone-900/60 backdrop-blur-sm" id="mobile-menu-backdrop"></div>
    <div class="mobile-panel relative mx-4 mt-20 bg-white rounded-2xl shadow-2xl border border-stone-200 overflow-hidden">
      <nav class="p-2">
        <a data-href="home-hash-departments" href="/#departments" class="mobile-link flex items-center gap-3 px-4 py-3.5 rounded-xl text-base font-semibold text-stone-800 hover:bg-stone-50 transition-colors">
          <svg class="w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <span data-t="nav.departments">{t(lang, 'nav.departments')}</span>
        </a>
        <a data-href="home-hash-clinics" href="/#clinics" class="mobile-link flex items-center gap-3 px-4 py-3.5 rounded-xl text-base font-semibold text-stone-800 hover:bg-stone-50 transition-colors">
          <svg class="w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          <span data-t="nav.clinics">{t(lang, 'nav.clinics')}</span>
        </a>
        <a data-href="home-hash-about" href="/#about" class="mobile-link flex items-center gap-3 px-4 py-3.5 rounded-xl text-base font-semibold text-stone-800 hover:bg-stone-50 transition-colors">
          <svg class="w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span data-t="nav.about">{t(lang, 'nav.about')}</span>
        </a>
        <a data-href="home-hash-contact" href="/#contact" class="mobile-link flex items-center gap-3 px-4 py-3.5 rounded-xl text-base font-semibold text-stone-800 hover:bg-stone-50 transition-colors">
          <svg class="w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span data-t="nav.contact">{t(lang, 'nav.contact')}</span>
        </a>
        <a data-href="patients" href="/patients/" class="mobile-link flex items-center gap-3 px-4 py-3.5 rounded-xl text-base font-semibold text-stone-800 hover:bg-stone-50 transition-colors">
          <svg class="w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <span data-t="nav.patients">{t(lang, 'nav.patients')}</span>
        </a>
      </nav>
      <div class="border-t border-stone-100 p-4">
        <a href="tel:+38232325602" class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span data-t="emergency.mobile">{t(lang, 'emergency.mobile')}</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main content -->
  <main class="flex-1 flex items-center">
    <section class="py-16 sm:py-20 lg:py-24 w-full">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-lg mx-auto text-center">
          <div class="w-20 h-20 rounded-2xl bg-stone-100 border border-stone-200 flex items-center justify-center mx-auto mb-8">
            <svg class="w-10 h-10 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
            </svg>
          </div>
          <h1 class="text-7xl sm:text-8xl font-extrabold text-stone-900 mb-4">404</h1>
          <p class="text-xl sm:text-2xl font-bold text-stone-900 mb-3" data-t="error.404.title">{t(lang, 'error.404.title')}</p>
          <p class="text-stone-500 mb-10 leading-relaxed" data-t="error.404.desc">{t(lang, 'error.404.desc')}</p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a data-href="home" href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
              <span data-t="error.404.home">{t(lang, 'error.404.home')}</span>
            </a>
            <a href="tel:+38232325602" class="inline-flex items-center gap-2 px-6 py-3 bg-white border border-stone-200 hover:border-stone-300 text-stone-700 text-sm font-semibold rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <span data-t="error.404.call">{t(lang, 'error.404.call')}</span> — <span data-t="header.phone">{t(lang, 'header.phone')}</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-stone-900 text-stone-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        <div class="sm:col-span-2 lg:col-span-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-lg bg-emerald-600 flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            </div>
            <span class="text-base font-bold text-white" data-t="header.name">{t(lang, 'header.name')}</span>
          </div>
          <p class="text-sm leading-relaxed" data-t="footer.brand.desc">{t(lang, 'footer.brand.desc')}</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4" data-t="footer.nav">{t(lang, 'footer.nav')}</h3>
          <ul class="space-y-2.5">
            <li><a data-href="home-hash-departments" href="/#departments" class="text-sm hover:text-white transition-colors" data-t="nav.departments">{t(lang, 'nav.departments')}</a></li>
            <li><a data-href="home-hash-clinics" href="/#clinics" class="text-sm hover:text-white transition-colors" data-t="nav.clinics">{t(lang, 'nav.clinics')}</a></li>
            <li><a data-href="home-hash-about" href="/#about" class="text-sm hover:text-white transition-colors" data-t="nav.about">{t(lang, 'nav.about')}</a></li>
            <li><a data-href="home-hash-contact" href="/#contact" class="text-sm hover:text-white transition-colors" data-t="nav.contact">{t(lang, 'nav.contact')}</a></li>
            <li><a data-href="patients" href="/patients/" class="text-sm hover:text-white transition-colors" data-t="nav.patients">{t(lang, 'nav.patients')}</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4" data-t="footer.contact">{t(lang, 'footer.contact')}</h3>
          <ul class="space-y-2.5 text-sm">
            <li><a href="tel:+38232325602" class="hover:text-white transition-colors" data-t="emergency.phone">{t(lang, 'emergency.phone')}</a></li>
            <li><a href="mailto:obk@t-com.me" class="hover:text-white transition-colors">obk@t-com.me</a></li>
            <li><span data-t="contact.address.street">{t(lang, 'contact.address.street')}</span>, 85331 Kotor</li>
            <li data-t="contact.address.city">{t(lang, 'contact.address.city').split(',').pop()?.trim()}</li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4" data-t="footer.links">{t(lang, 'footer.links')}</h3>
          <ul class="space-y-2.5 text-sm">
            <li><a href="https://ezdravlje.me" target="_blank" rel="noopener" class="hover:text-white transition-colors" data-t="footer.links.ezdravlje">{t(lang, 'footer.links.ezdravlje')}</a></li>
            <li><a href="tel:+38232325602" class="hover:text-white transition-colors" data-t="footer.links.emergency">{t(lang, 'footer.links.emergency')}</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-12 pt-8 border-t border-stone-800 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs text-stone-500" data-t="footer.copyright">{t(lang, 'footer.copyright')}</p>
        <p class="text-xs text-stone-500">Website by <a href="https://egorsky.com" target="_blank" rel="noopener" class="text-stone-400 hover:text-white transition-colors">egorsky.com</a></p>
      </div>
    </div>
  </footer>

  <script define:vars={{ allTranslations }}>
    (function() {
      const LOCALES = ['cnr','en','ru','uk','tr','de','es','fr'];
      const DEFAULT = 'cnr';

      // Detect language: cookie > browser > default
      function detect() {
        const cookie = document.cookie.match(/preferred_lang=(\w+)/);
        if (cookie && LOCALES.includes(cookie[1])) return cookie[1];
        const langs = navigator.languages || [navigator.language];
        for (const tag of langs) {
          const base = tag.toLowerCase().split('-')[0];
          if (LOCALES.includes(base)) return base;
          if (['sr','bs','hr'].includes(base)) return 'cnr';
        }
        return DEFAULT;
      }

      const lang = detect();
      if (lang === DEFAULT) return; // Already cnr, no swap needed

      const tr = allTranslations[lang];
      if (!tr) return;

      // Update html lang
      document.documentElement.lang = lang;

      // Update all [data-t] elements
      document.querySelectorAll('[data-t]').forEach(function(el) {
        const key = el.getAttribute('data-t');
        if (key && tr[key]) el.textContent = tr[key];
      });

      // Update links: home, patients, nav with hash
      const home = lang === DEFAULT ? '/' : '/' + lang + '/';
      const patients = lang === DEFAULT ? '/patients/' : '/' + lang + '/patients/';
      document.querySelectorAll('[data-href]').forEach(function(el) {
        const type = el.getAttribute('data-href');
        if (type === 'home') el.setAttribute('href', home);
        else if (type === 'patients') el.setAttribute('href', patients);
        else if (type && type.startsWith('home-hash-')) {
          el.setAttribute('href', home + '#' + type.replace('home-hash-', ''));
        }
      });

      // Update title
      document.title = '404 — ' + (tr['site.title'] || 'JZUOB Kotor');
    })();
  </script>

  <script>
    // Mobile menu
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuBackdrop = document.getElementById('mobile-menu-backdrop');
    function openMenu() { mobileMenu?.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeMenu() { mobileMenu?.classList.remove('open'); document.body.style.overflow = ''; }
    menuBtn?.addEventListener('click', () => { mobileMenu?.classList.contains('open') ? closeMenu() : openMenu(); });
    menuBackdrop?.addEventListener('click', closeMenu);
    mobileMenu?.querySelectorAll('.mobile-link').forEach(link => { link.addEventListener('click', closeMenu); });
  </script>
</body>
</html>
